{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "jarvis-electron",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 0
    },
    {
      "name": "jarvis-ui-preview",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "5599", "--directory", "src"],
      "port": 5599
    },
    {
      "name": "jarvis-website",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "website"],
      "port": 3000
    }
  ]
}
