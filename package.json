{
  "name": "jarvis",
  "version": "1.3.0",
  "description": "JARVIS - Futuristischer KI-Sprachassistent im Iron-Man-Stil",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "author": "Luca",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.24.1",
    "@xenova/transformers": "^2.17.2",
    "electron-updater": "^6.8.9",
    "extract-zip": "^2.0.1",
    "pdfkit": "^0.19.1",
    "systeminformation": "^5.31.11"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.luca.jarvis",
    "productName": "JARVIS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "core/**/*",
      "skills/**/*",
      "native/**/*",
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "native/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JARVIS",
      "multiLanguageInstaller": true,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "lucakroeger350-ctrl",
      "repo": "jarvis-ai-assistant"
    }
  }
}
